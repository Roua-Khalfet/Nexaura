# Django Configuration
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Google OAuth Configuration
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Serper API (for web search)
SERPER_API_KEY=your-serper-api-key

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4j123

# Qdrant Configuration (local)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_PATH=
QDRANT_COLLECTION_NAME=complianceguard_chunks

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=qwen3-embedding:0.6b
OLLAMA_MODEL=llama3.1

# Azure OpenAI Configuration (optional - for advanced features)
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=2024-02-15-preview
AZURE_MODEL=gpt-4o

# Processing Configuration
CHUNK_SIZE=1500
CHUNK_OVERLAP=300

# ============================================
# Tech Agent Configuration (Port 8005 - ISOLATED)
# ============================================
# Tech Agent services run on isolated ports to avoid conflicts:
# - API: http://localhost:8005
# - Redis: localhost:6381
# - Qdrant: http://localhost:6335 (REST), localhost:6336 (gRPC)
#
# Start tech-agent services separately:
#   cd backend/tech-agent && docker compose up -d
#
NEXT_PUBLIC_TECH_AGENT_BASE=http://localhost:8005/api/ta
# NEXT_PUBLIC_API_KEY is set in frontend/.env

# ============================================
# TeamBuilder Configuration (Port 8001)
# ============================================
# Note: TeamBuilder backend runs on port 8001
# See backend/teambuilder/.env for full config
# 
# TeamBuilder uses:
# - PostgreSQL on port 5433
# - Redis on port 6380
# - Backend API on port 8001
#
# Update Google OAuth redirect URI to:
# http://localhost:8001/api/v1/auth/google/callback
