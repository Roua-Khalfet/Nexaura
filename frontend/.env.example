# Frontend Environment Configuration

# ============================================
# Tech Agent API Endpoint (Port 8005 - ISOLATED)
# ============================================
# Tech Agent API runs on isolated port to avoid conflicts with other services.
# Default points to localhost tech-agent stack started via:
#   cd backend/tech-agent && docker compose up -d
#
# For production, update to your deployed tech-agent endpoint.
NEXT_PUBLIC_TECH_AGENT_BASE=http://localhost:8005/api/ta

# API Key for Tech Agent authentication
NEXT_PUBLIC_API_KEY=your_api_key

# ============================================
# ComplianceGuard Backend (Port 8000)
# ============================================
# Main Startify backend for legal compliance features
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# ============================================
# Serper API Key (Optional - for web search in Tech Agent)
# ============================================
# Get from: https://serper.dev
NEXT_PUBLIC_SERPER_API_KEY=

# ============================================
# Groq API Key (Optional - for LLM in Tech Agent)
# ============================================
# Get from: https://groq.com
NEXT_PUBLIC_GROQ_API_KEY=

# ============================================
# vLLM API Key (Optional - for alternative LLM)
# ============================================
NEXT_PUBLIC_VLLM_API_KEY=

# ============================================
# Development Only
# ============================================
# NODE_ENV=development
